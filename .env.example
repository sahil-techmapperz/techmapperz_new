# Database Configuration
MONGO_URL=mongodb://localhost:27017/techmapperz
# Or use MongoDB Atlas connection string:
# MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/techmapperz?retryWrites=true&w=majority

# JWT Secret for Authentication
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ImageKit Configuration (for file uploads)
# Get these from your ImageKit dashboard: https://imagekit.io/dashboard
ImagekitpublicKey=your-imagekit-public-key
ImagekitprivateKey=your-imagekit-private-key
ImagekiturlEndpoint=your-imagekit-url-endpoint

# Site Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# For production, use:
# NEXT_PUBLIC_BASE_URL=https://www.techmapperz.com

# Node Environment
NODE_ENV=development
# For production, use:
# NODE_ENV=production
